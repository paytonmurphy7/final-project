{
  "apiVersion": "1",
  "baseUrlEnv": "API_BASE",
  "directory": "examples/video-games",
  "resources": [
    {
      "type": "Platform",
      "path": "/api/platforms",
      "file": "platforms.csv"
    },
    {
      "type": "Game",
      "path": "/api/games",
      "file": "games.csv"
    },
    {
      "type": "Review",
      "path": "/api/reviews",
      "file": "reviews.csv"
    }
  ],
  "usersFile": "users.csv",
  "seedUserColumn": "seed_as"
}
