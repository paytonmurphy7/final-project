{
  "name": "api-generator",
  "version": "1.0.0",
  "description": "Declarative CRUD API generator starter app",
  "main": "src/server.js",
  "scripts": {
    "build:example": "node src/cli/buildExample.js",
    "validate": "node src/cli/validate.js",
    "generate": "node src/cli/generate.js",
    "generate:committed": "node src/cli/generate.js --yes --skip-db-reset",
    "seed": "node src/cli/seed.js",
    "db:bootstrap": "node src/cli/bootstrap.js",
    "export:csv": "node src/cli/exportCsv.js",
    "export:example": "node src/cli/exportExample.js",
    "start": "node src/server.js",
    "start:railway": "node src/cli/bootstrap.js && node src/server.js",
    "start:railway:plants": "DATABASE_PROVIDER=postgres npm run build:example -- --dir plants --yes && DATABASE_PROVIDER=postgres node src/server.js",
    "dev": "nodemon --watch src --watch generated --ext js,json src/server.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.16.3",
    "swagger-ui-express": "^5.0.1",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
